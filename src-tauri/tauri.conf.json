{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Responsive Tester",
  "version": "0.2.0",
  "identifier": "com.kobecreative.responsivetester",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Responsive Tester",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/DanKobeCreative/responsive-tester/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3MzY3Nzk0MDZFMEQ1REMKUldUYzFlQUdsSGMyTjNLNEtHb1lBTWttaG5nOFlEWVpXTUVJdUIvUTJQQzZzQm1FM21RSFpxdmsK"
    }
  }
}
